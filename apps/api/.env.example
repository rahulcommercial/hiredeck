# Hiredeck API — copy to .env and fill in
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
MAX_UPLOAD_MB=5
# Comma-separated. Cover 3000–3003 since Next.js falls forward when ports are taken.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003
