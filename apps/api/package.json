{
  "name": "@hiredeck/api",
  "version": "0.1.0",
  "private": true,
  "description": "FastAPI shim wrapper so pnpm workspaces can reference the Python service.",
  "scripts": {
    "dev": "uvicorn hiredeck_api.main:app --reload --port 8000",
    "start": "uvicorn hiredeck_api.main:app --host 0.0.0.0 --port 8000",
    "install:py": "pip install -e .[dev]",
    "lint": "ruff check .",
    "typecheck": "echo 'python typecheck via ruff'"
  }
}
